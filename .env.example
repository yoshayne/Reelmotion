# Database (Railway provides both)
DATABASE_URL=postgresql://postgres:password@localhost:5432/reelmotion
DATABASE_PUBLIC_URL=postgresql://postgres:password@localhost:5432/reelmotion

# Clerk Auth
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# Railway Storage Bucket (S3-compatible)
REELMOTION_BUCKET_NAME=...
REELMOTION_ENDPOINT=...
REELMOTION_ACCESS_KEY_ID=...
REELMOTION_SECRET_ACCESS_KEY=...
REELMOTION_DEFAULT_REGION=us-east-1
STORAGE_PUBLIC_URL=https://...

# Redis (Railway Redis)
REDIS_URL=redis://localhost:6379

# Mux (video player)
MUX_TOKEN_ID=...
MUX_TOKEN_SECRET=...

# Brevo (email)
BREVO_API_KEY=...

# App
PORT=3000
APP_URL=https://reelmotion.up.railway.app
NODE_ENV=production
